# ──────────────────────────────────────────────────────────────────────────
# Outreach SMTP/IMAP config — copia este archivo como .env.outreach y
# rellena los valores. .env.outreach NO se commitea (está en .gitignore).
# ──────────────────────────────────────────────────────────────────────────

# Gmail SMTP — requiere 2FA activado + App Password
# Crea la App Password en: https://myaccount.google.com/apppasswords
GMAIL_USER=tu.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Nombre para el campo "From"
FROM_NAME=Diego — Cluberly

# IMAP (opcional, solo para outreach-check-replies.cjs)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
