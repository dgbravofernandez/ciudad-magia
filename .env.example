# =============================================================
# Supabase
# =============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================
# Google APIs
# =============================================================
# OAuth2 (para Gmail y Drive del club)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourapp.com/api/google/callback

# Service Account (para leer/escribir Google Sheets)
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
# Base64 del JSON de la service account key
GOOGLE_SERVICE_ACCOUNT_KEY=base64-encoded-service-account-json

# =============================================================
# App
# =============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Clave para encriptar refresh tokens de Google OAuth guardados en DB
APP_SECRET=your-32-char-random-secret-here
